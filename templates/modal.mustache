{{!
    @template tiny_chemjax/modal

    Dialog to write ChemJax notation with a live preview.

    Classes required for JS:
    * tiny_chemjax_source
    * tiny_chemjax_preview

    Data attributes required for JS:
    * data-action="save", data-action="help"

    Context variables required for this template:
    * elementid - unique id prefix for form fields
    * source - initial notation (may be empty)
    * isupdating - whether an existing selection is being edited
    * rendererurl - URL of the filter_chemjax renderer page

    Example context (json):
    {
        "elementid": "exampleId",
        "source": "\\cjx{CH_3 -CH_3}",
        "isupdating": false,
        "rendererurl": "https://example.com/filter/chemjax/renderer.html"
    }
}}
{{< core/modal }}
    {{$title}}{{#str}} dialogtitle, tiny_chemjax {{/str}}{{/title}}
    {{$body}}
        <form class="mform" id="{{uniqid}}">
            <div class="mb-3">
                <label for="{{elementid}}_tiny_chemjax_source">{{#str}} notationlabel, tiny_chemjax {{/str}}</label>
                <textarea class="form-control tiny_chemjax_source" id="{{elementid}}_tiny_chemjax_source"
                    rows="4" spellcheck="false">{{source}}</textarea>
            </div>
            <div class="mb-3">
                <span class="d-block mb-1">{{#str}} previewlabel, tiny_chemjax {{/str}}</span>
                <iframe class="tiny_chemjax_preview w-100 border rounded" style="height: 150px;"
                    src="{{rendererurl}}" title="{{#str}} previewlabel, tiny_chemjax {{/str}}"></iframe>
            </div>
        </form>
    {{/body}}
    {{$footer}}
        <button type="button" class="btn btn-secondary me-auto" data-action="help">
            {{#str}} helpbutton, tiny_chemjax {{/str}}
        </button>
        <button type="button" class="btn btn-primary" data-action="save">
            {{#isupdating}}{{#str}} update, tiny_chemjax {{/str}}{{/isupdating}}
            {{^isupdating}}{{#str}} insert, tiny_chemjax {{/str}}{{/isupdating}}
        </button>
    {{/footer}}
{{/ core/modal }}
